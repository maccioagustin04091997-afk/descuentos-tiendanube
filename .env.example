# =============================================
# CONFIGURACION - Descuentos por Cantidad
# =============================================
# Copia este archivo como ".env" y completa los valores

# Credenciales de tu App en Tienda Nube
# Obtenelas en: https://partners.tiendanube.com/
TN_CLIENT_ID=TU_CLIENT_ID_AQUI
TN_CLIENT_SECRET=TU_CLIENT_SECRET_AQUI

# URL pública de tu aplicación (sin barra al final)
# En local usa ngrok: https://XXXX.ngrok.io
# En producción usa tu dominio: https://mi-app.com
APP_URL=https://TU-URL-PUBLICA.ngrok.io

# Email de contacto (requerido por la API de Tienda Nube)
CONTACT_EMAIL=tu@email.com

# Puerto del servidor (opcional, default: 3000)
PORT=3000
